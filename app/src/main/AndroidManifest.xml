<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Declare telephony hardware feature optional for ChromeOS compliance -->
    <uses-feature android:name="android.hardware.telephony" android:required="false" />

    <!-- Contact and Call Log Permissions -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    
    <!-- SMS Permissions -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <!-- Read SMS permission for delivery/status on OEMs (API 29–35) -->
    <uses-permission android:name="android.permission.READ_SMS" />
    
    <!-- Foreground service permission (Android 9+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Foreground service type permissions for Android 14+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    
    <!-- Boot completed permission to start services automatically -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- Notifications permission for Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Wake lock to keep CPU awake during processing -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Exact alarm permission for keepalive scheduling on Android 12+ -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Exact alarm permission for Android 14+ policy -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    
    <!-- Storage Permissions for Export -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" 
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" 
        android:maxSdkVersion="32" />
    
    <!-- For Android 13+ storage -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" 
        tools:ignore="ScopedStorage" />

    <application
        android:name=".AutoMessageApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="Auto Messaging"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AutoMessage">
        <!-- Splash Screen Activity -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AutoMessage.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Main Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AutoMessage"
            android:windowSoftInputMode="adjustResize" />
        
        <!-- Call Detection Service -->
        <service
            android:name=".service.CallDetectionService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        
        <!-- Phone State Broadcast Receiver -->
        <receiver
            android:name=".service.PhoneStateReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
                <action android:name="android.intent.action.NEW_OUTGOING_CALL" />
            </intent-filter>
        </receiver>
        
        <!-- SMS Broadcast Receiver (protected) -->
        <receiver
            android:name=".service.SmsReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
        
        <!-- Call Verification Service -->
        <service
            android:name=".service.CallVerificationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        
        <!-- Boot Receiver to start services -->
        <receiver
            android:name=".service.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
        
        <!-- Manual Verification Receiver -->
        <receiver
            android:name=".service.ManualVerificationReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.avinashpatil.app.automessage.ACTION_MANUAL_VERIFICATION" />
                <action android:name="com.avinashpatil.app.automessage.ACTION_MANUAL_SEND" />
            </intent-filter>
        </receiver>

        <!-- KeepAlive Receiver to revive CallDetectionService -->
        <receiver
            android:name=".receiver.KeepAliveReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.avinashpatil.app.automessage.ACTION_KEEPALIVE" />
            </intent-filter>
        </receiver>

        <!-- SMS Status Receiver for SENT/DELIVERED callbacks -->
        <receiver
            android:name=".receiver.SmsStatusReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.avinashpatil.app.automessage.SMS_SENT" />
                <action android:name="com.avinashpatil.app.automessage.SMS_DELIVERED" />
            </intent-filter>
        </receiver>
        
    </application>

</manifest>
